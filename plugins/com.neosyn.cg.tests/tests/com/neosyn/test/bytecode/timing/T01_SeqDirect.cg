/*
 * Phase 1 timing test T01 — sequential producer → sequential consumer
 * via push port. No combinational task in the path.
 *
 * Expectation (both before and after Phase 2 of BYTECODE_REFACTOR_PLAN):
 *   the consumer sees each value with a 1-cycle latency (the push port
 *   has registered semantics).
 *
 * The consumer asserts that the sequence of values it sees is exactly
 * 1, 2, 3, 4, 5 in order. After 5 successful reads it sets `finished`
 * and the network terminates.
 */
package com.neosyn.test.bytecode.timing;

network T01_SeqDirect {

    properties {
        test: { terminate: "checker.finished" }
    }

    producer = new task {
        out push u8 value;
        u8 count;

        void setup() {
            count = 0;
        }

        void loop() {
            count++;
            value.write(count);
        }
    };

    checker = new task {
        in push u8 value;

        u8 expected;
        bool finished;

        void setup() {
            expected = 1;
            finished = false;
        }

        void loop() {
            if (!finished) {
                u8 v = value.read();
                assert(v == expected);
                if (expected == 5) {
                    print("T01_SeqDirect PASS\n");
                    finished = true;
                } else {
                    expected++;
                }
            }
        }
    };

    checker.reads(producer.value);
}
