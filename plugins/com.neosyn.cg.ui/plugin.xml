<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>

<plugin>

    <extension
            point="org.eclipse.ui.editors">
        <editor
              class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.XtextEditor"
              contributorClass="org.eclipse.ui.editors.text.TextEditorActionContributor"
              default="true"
              extensions="cg"
              icon="icons/cx_obj.gif"
              id="com.neosyn.cg.Cx"
              name="Cx Editor">
        </editor>
    </extension>
    <extension
        point="org.eclipse.ui.handlers">
        <handler
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.hyperlinking.OpenDeclarationHandler"
            commandId="org.eclipse.xtext.ui.editor.hyperlinking.OpenDeclaration">
            <activeWhen>
                <reference
                    definitionId="com.neosyn.cg.Cx.Editor.opened">
                </reference>
            </activeWhen>
        </handler>
        <handler
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.handler.ValidateActionHandler"
            commandId="com.neosyn.cg.Cx.validate">
         <activeWhen>
            <reference
                    definitionId="com.neosyn.cg.Cx.Editor.opened">
            </reference>
         </activeWhen>
      	</handler>
      	<!-- copy qualified name -->
        <handler
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedNameHandler"
            commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedName">
            <activeWhen>
				<reference definitionId="com.neosyn.cg.Cx.Editor.opened" />
            </activeWhen>
        </handler>
        <handler
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.copyqualifiedname.OutlineCopyQualifiedNameHandler"
            commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.OutlineCopyQualifiedName">
            <activeWhen>
            	<and>
            		<reference definitionId="com.neosyn.cg.Cx.XtextEditor.opened" />
	                <iterate>
						<adapt type="org.eclipse.xtext.ui.editor.outline.IOutlineNode" />
					</iterate>
				</and>
            </activeWhen>
        </handler>
    </extension>
    <extension point="org.eclipse.core.expressions.definitions">
        <definition id="com.neosyn.cg.Cx.Editor.opened">
            <and>
                <reference definitionId="isActiveEditorAnInstanceOfXtextEditor"/>
                <with variable="activeEditor">
                    <test property="org.eclipse.xtext.ui.editor.XtextEditor.languageName"
                        value="com.neosyn.cg.Cx"
                        forcePluginActivation="true"/>
                </with>
            </and>
        </definition>
        <definition id="com.neosyn.cg.Cx.XtextEditor.opened">
            <and>
                <reference definitionId="isXtextEditorActive"/>
                <with variable="activeEditor">
                    <test property="org.eclipse.xtext.ui.editor.XtextEditor.languageName"
                        value="com.neosyn.cg.Cx"
                        forcePluginActivation="true"/>
                </with>
            </and>
        </definition>
    </extension>
    <extension
            point="org.eclipse.ui.preferencePages">
        <page
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.preferences.LanguageRootPreferencePage"
            id="com.neosyn.cg.Cx"
            name="Cx">
            <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
        </page>
        <page
            category="com.neosyn.cg.Cx"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.syntaxcoloring.SyntaxColoringPreferencePage"
            id="com.neosyn.cg.Cx.coloring"
            name="Syntax Coloring">
            <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
        </page>
        <page
            category="com.neosyn.cg.Cx"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.templates.XtextTemplatePreferencePage"
            id="com.neosyn.cg.Cx.templates"
            name="Templates">
            <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
        </page>
    </extension>
    <extension
            point="org.eclipse.ui.propertyPages">
        <page
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.preferences.LanguageRootPreferencePage"
            id="com.neosyn.cg.Cx"
            name="Cx">
            <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
            <enabledWhen>
	            <adapt type="org.eclipse.core.resources.IProject"/>
			</enabledWhen>
	        <filter name="projectNature" value="org.eclipse.xtext.ui.shared.xtextNature"/>
        </page>
    </extension>
    <extension
        point="org.eclipse.ui.keywords">
        <keyword
            id="com.neosyn.cg.ui.keyword_Cx"
            label="Cx"/>
    </extension>
    <extension
         point="org.eclipse.ui.commands">
      <command
            description="Trigger expensive validation"
            id="com.neosyn.cg.Cx.validate"
            name="Validate">
      </command>
      <!-- copy qualified name -->
      <command
            id="org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedName"
            categoryId="org.eclipse.ui.category.edit"
            description="Copy the qualified name for the selected element"
            name="Copy Qualified Name">
      </command>
      <command
            id="org.eclipse.xtext.ui.editor.copyqualifiedname.OutlineCopyQualifiedName"
            categoryId="org.eclipse.ui.category.edit"
            description="Copy the qualified name for the selected element"
            name="Copy Qualified Name">
      </command>
    </extension>
    <extension point="org.eclipse.ui.menus">
        <menuContribution
            locationURI="popup:#TextEditorContext?after=group.edit">
             <command
                 commandId="com.neosyn.cg.Cx.validate"
                 style="push"
                 tooltip="Trigger expensive validation">
            <visibleWhen checkEnabled="false">
                <reference
                    definitionId="com.neosyn.cg.Cx.Editor.opened">
                </reference>
            </visibleWhen>
         </command>
         </menuContribution>
         <!-- copy qualified name -->
         <menuContribution locationURI="popup:#TextEditorContext?after=copy">
         	<command commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedName"
         		style="push" tooltip="Copy Qualified Name">
            	<visibleWhen checkEnabled="false">
                	<reference definitionId="com.neosyn.cg.Cx.Editor.opened" />
            	</visibleWhen>
         	</command>
         </menuContribution>
         <menuContribution locationURI="menu:edit?after=copy">
         	<command commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedName"
            	style="push" tooltip="Copy Qualified Name">
            	<visibleWhen checkEnabled="false">
                	<reference definitionId="com.neosyn.cg.Cx.Editor.opened" />
            	</visibleWhen>
         	</command>
         </menuContribution>
         <menuContribution locationURI="popup:org.eclipse.xtext.ui.outline?after=additions">
			<command commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.OutlineCopyQualifiedName"
				style="push" tooltip="Copy Qualified Name">
         		<visibleWhen checkEnabled="false">
	            	<and>
	            		<reference definitionId="com.neosyn.cg.Cx.XtextEditor.opened" />
						<iterate>
							<adapt type="org.eclipse.xtext.ui.editor.outline.IOutlineNode" />
						</iterate>
					</and>
				</visibleWhen>
			</command>
         </menuContribution>
    </extension>
    <extension point="org.eclipse.ui.menus">
		<menuContribution locationURI="popup:#TextEditorContext?endof=group.find">
			<command commandId="org.eclipse.xtext.ui.editor.FindReferences">
				<visibleWhen checkEnabled="false">
                	<reference definitionId="com.neosyn.cg.Cx.Editor.opened">
                	</reference>
            	</visibleWhen>
			</command>
		</menuContribution>
	</extension>
	<extension point="org.eclipse.ui.handlers">
	    <handler
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.findrefs.FindReferencesHandler"
            commandId="org.eclipse.xtext.ui.editor.FindReferences">
            <activeWhen>
                <reference
                    definitionId="com.neosyn.cg.Cx.Editor.opened">
                </reference>
            </activeWhen>
        </handler>
    </extension>

<!-- adding resource factories -->

	<extension
		point="org.eclipse.emf.ecore.extension_parser">
		<parser
			class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.resource.IResourceFactory"
			type="cg">
		</parser>
	</extension>
	<extension point="org.eclipse.xtext.extension_resourceServiceProvider">
        <resourceServiceProvider
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.resource.IResourceUIServiceProvider"
            uriExtension="cg">
        </resourceServiceProvider>
    </extension>


    <!-- marker definitions for com.neosyn.cg.Cx -->
    <extension
            id="cx.check.fast"
            name="Cx Problem"
            point="org.eclipse.core.resources.markers">
        <super type="org.eclipse.xtext.ui.check.fast"/>
        <persistent value="true"/>
    </extension>
    <extension
            id="cx.check.normal"
            name="Cx Problem"
            point="org.eclipse.core.resources.markers">
        <super type="org.eclipse.xtext.ui.check.normal"/>
        <persistent value="true"/>
    </extension>
    <extension
            id="cx.check.expensive"
            name="Cx Problem"
            point="org.eclipse.core.resources.markers">
        <super type="org.eclipse.xtext.ui.check.expensive"/>
        <persistent value="true"/>
    </extension>

   <extension
         point="org.eclipse.xtext.builder.participant">
      <participant
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.builder.IXtextBuilderParticipant"
            fileExtensions="cg"
            >
      </participant>
   </extension>
   <extension
            point="org.eclipse.ui.preferencePages">
        <page
            category="com.neosyn.cg.Cx"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.builder.preferences.BuilderPreferencePage"
            id="com.neosyn.cg.Cx.compiler.preferencePage"
            name="Compiler">
            <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
        </page>
    </extension>
    <extension
            point="org.eclipse.ui.propertyPages">
        <page
            category="com.neosyn.cg.Cx"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.builder.preferences.BuilderPreferencePage"
            id="com.neosyn.cg.Cx.compiler.propertyPage"
            name="Compiler">
            <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
            <enabledWhen>
	            <adapt type="org.eclipse.core.resources.IProject"/>
			</enabledWhen>
	        <filter name="projectNature" value="org.eclipse.xtext.ui.shared.xtextNature"/>
        </page>
    </extension>

	<!-- Quick Outline -->
	<extension
		point="org.eclipse.ui.handlers">
		<handler
			class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.outline.quickoutline.ShowQuickOutlineActionHandler"
			commandId="org.eclipse.xtext.ui.editor.outline.QuickOutline">
			<activeWhen>
				<reference
					definitionId="com.neosyn.cg.Cx.Editor.opened">
				</reference>
			</activeWhen>
		</handler>
	</extension>
	<extension
		point="org.eclipse.ui.commands">
		<command
			description="Open the quick outline."
			id="org.eclipse.xtext.ui.editor.outline.QuickOutline"
			name="Quick Outline">
		</command>
	</extension>
	<extension point="org.eclipse.ui.menus">
		<menuContribution
			locationURI="popup:#TextEditorContext?after=group.open">
			<command commandId="org.eclipse.xtext.ui.editor.outline.QuickOutline"
				style="push"
				tooltip="Open Quick Outline">
				<visibleWhen checkEnabled="false">
					<reference definitionId="com.neosyn.cg.Cx.Editor.opened"/>
				</visibleWhen>
			</command>
		</menuContribution>
	</extension>
    <!-- quickfix marker resolution generator for com.neosyn.cg.Cx -->
    <extension
            point="org.eclipse.ui.ide.markerResolution">
        <markerResolutionGenerator
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.quickfix.MarkerResolutionGenerator"
            markerType="com.neosyn.cg.ui.cx.check.fast">
            <attribute
                name="FIXABLE_KEY"
                value="true">
            </attribute>
        </markerResolutionGenerator>
        <markerResolutionGenerator
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.quickfix.MarkerResolutionGenerator"
            markerType="com.neosyn.cg.ui.cx.check.normal">
            <attribute
                name="FIXABLE_KEY"
                value="true">
            </attribute>
        </markerResolutionGenerator>
        <markerResolutionGenerator
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.quickfix.MarkerResolutionGenerator"
            markerType="com.neosyn.cg.ui.cx.check.expensive">
            <attribute
                name="FIXABLE_KEY"
                value="true">
            </attribute>
        </markerResolutionGenerator>
    </extension>
   	<!-- Rename Refactoring -->
	<extension point="org.eclipse.ui.handlers">
		<handler
			class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.refactoring.ui.DefaultRenameElementHandler"
			commandId="org.eclipse.xtext.ui.refactoring.RenameElement">
			<activeWhen>
				<reference
					definitionId="com.neosyn.cg.Cx.Editor.opened">
				</reference>
			</activeWhen>
		</handler>
	</extension>
    <extension point="org.eclipse.ui.menus">
         <menuContribution
            locationURI="popup:#TextEditorContext?after=group.edit">
         <command commandId="org.eclipse.xtext.ui.refactoring.RenameElement"
               style="push">
            <visibleWhen checkEnabled="false">
               <reference
                     definitionId="com.neosyn.cg.Cx.Editor.opened">
               </reference>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension point="org.eclipse.ui.preferencePages">
	    <page
	        category="com.neosyn.cg.Cx"
	        class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.refactoring.ui.RefactoringPreferencePage"
	        id="com.neosyn.cg.Cx.refactoring"
	        name="Refactoring">
	        <keywordReference id="com.neosyn.cg.ui.keyword_Cx"/>
	    </page>
	</extension>

  <extension point="org.eclipse.compare.contentViewers">
    <viewer id="com.neosyn.cg.Cx.compare.contentViewers"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.compare.InjectableViewerCreator"
            extensions="cg">
    </viewer>
  </extension>
  <extension point="org.eclipse.compare.contentMergeViewers">
    <viewer id="com.neosyn.cg.Cx.compare.contentMergeViewers"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.compare.InjectableViewerCreator"
            extensions="cg" label="Cx Compare">
     </viewer>
  </extension>
  <extension point="org.eclipse.ui.editors.documentProviders">
    <provider id="com.neosyn.cg.Cx.editors.documentProviders"
            class="com.neosyn.cg.ui.CgExecutableExtensionFactory:org.eclipse.xtext.ui.editor.model.XtextDocumentProvider"
            extensions="cg">
    </provider>
  </extension>
  <extension point="org.eclipse.team.core.fileTypes">
    <fileTypes
            extension="cg"
            type="text">
    </fileTypes>
  </extension>

  <extension
        point="org.eclipse.ui.editors.annotationTypes">
     <type
           markerType="com.neosyn.cg.cycleIndicator"
           name="com.neosyn.cg.ui.cycleIndicator">
     </type>
  </extension>
  <extension
        point="org.eclipse.ui.editors.markerAnnotationSpecification">
     <specification
           annotationImageProvider="com.neosyn.cg.ui.annotations.CxImageProvider"
           annotationType="com.neosyn.cg.ui.cycleIndicator"
           colorPreferenceKey="cycleIndicatorColor"
           colorPreferenceValue="180,207,205"
           includeOnPreferencePage="true"
           label="Cycle Indicators"
           overviewRulerPreferenceKey="cycleIndicatorInOverviewRuler"
           overviewRulerPreferenceValue="false"
           textPreferenceKey="cycleIndicator"
           textPreferenceValue="false"
           verticalRulerPreferenceKey="cycleIndicatorInVerticalRuler"
           verticalRulerPreferenceValue="true">
     </specification>
  </extension>
  <extension
         point="org.eclipse.ui.newWizards">
      <wizard
            category="com.neosyn.ide.ui.categoryNeosyn"
            class="com.neosyn.cg.ui.wizards.NewTaskWizard"
            hasPages="true"
            icon="icons/type_task.png"
            id="com.neosyn.cg.ui.wizards.newTask"
            name="Cx task"
            project="false">
         <description>
            Create a new Cx task
         </description>
      </wizard>
      <wizard
            category="com.neosyn.ide.ui.categoryNeosyn"
            class="com.neosyn.cg.ui.wizards.NewNetworkWizard"
            hasPages="true"
            icon="icons/type_network.png"
            id="com.neosyn.cg.ui.wizards.newNetwork"
            name="Cx network"
            project="false">
         <description>
            Create a new Cx network
         </description>
      </wizard>
      <wizard
            category="com.neosyn.ide.ui.categoryNeosyn"
            class="com.neosyn.cg.ui.wizards.NewBundleWizard"
            hasPages="true"
            icon="icons/type_bundle.png"
            id="com.neosyn.cg.ui.wizards.newBundle"
            name="Cx bundle"
            project="false">
         <description>
            Create a new Cx bundle
         </description>
      </wizard>
   </extension>
  <extension
        point="org.eclipse.ui.views">
     <view
           category="com.neosyn.ide.ui"
           class="com.neosyn.cg.ui.CgExecutableExtensionFactory:com.neosyn.cg.ui.views.FsmView"
           icon="icons/fsm.gif"
           id="com.neosyn.cg.ui.views.FsmView"
           name="FSM">
     </view>
     <view
           category="com.neosyn.ide.ui"
           class="com.neosyn.cg.ui.CgExecutableExtensionFactory:com.neosyn.cg.ui.views.GraphView"
           icon="icons/design.gif"
           id="com.neosyn.cg.ui.views.GraphView"
           name="Graph">
     </view>
  </extension>
  <extension
        point="org.eclipse.xtext.ui.shared.sharedStateContributingModule">
     <module
           class="com.neosyn.cg.builder.CxContributingModule">
     </module>
  </extension>
</plugin>
